# 台股AI個人化決策系統 v3.1 - .gitignore

# 環境變數（含敏感金鑰）
.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# 虛擬環境
venv/
.venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# 測試暫存
*.csv
*.xlsx
*.parquet

# 開發歸檔（不進入部署）
archive/

# 新聞 SQLite 資料庫（部署後由容器自動建立）
news_sentiment.db

# 分析快取目錄（部署後由容器自動建立）
data/cache/
